@model LabExam1.Models.Payroll
@{ ViewData["Title"] = "New Payroll"; }

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg: #0f1117; --surface: #1a1d27; --surface2: #22263a;
        --accent: #6c63ff; --text: #e8eaf6; --muted: #7b7f9e; --border: rgba(255,255,255,0.07);
        --input-bg: #13151f; --danger: #ff6584;
    }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; }
    .page { max-width: 520px; margin: 0 auto; padding: 2.5rem 1.5rem; }
    .page-title { font-family: 'Syne', sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.3rem;
        background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .page-sub { color: var(--muted); font-size: 0.875rem; margin-bottom: 2rem; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 2rem; }
    .form-group { margin-bottom: 1.25rem; }
    label { display: block; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.07em;
        color: var(--muted); margin-bottom: 0.4rem; }
    input, select { width: 100%; padding: 0.65rem 0.9rem; background: var(--input-bg);
        border: 1px solid var(--border); border-radius: 8px; color: var(--text);
        font-family: 'DM Sans', sans-serif; font-size: 0.9rem; box-sizing: border-box; transition: border 0.2s; }
    input:focus, select:focus { outline: none; border-color: var(--accent); }
    select option { background: var(--surface2); }
    .text-danger { color: var(--danger); font-size: 0.78rem; margin-top: 0.3rem; display: block; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .btn-submit { width: 100%; padding: 0.75rem; background: var(--accent); color: #fff;
        border: none; border-radius: 8px; font-size: 0.95rem; font-weight: 500;
        cursor: pointer; transition: all 0.2s; margin-top: 0.5rem; }
    .btn-submit:hover { background: #5a52e0; transform: translateY(-1px); }
    .back-link { display: inline-block; margin-top: 1.2rem; color: var(--muted); font-size: 0.85rem; text-decoration: none; }
    .back-link:hover { color: var(--text); }
    .hint { font-size: 0.75rem; color: var(--muted); margin-top: 0.3rem; }
</style>

<div class="page">
    <h1 class="page-title">New Payroll</h1>
    <p class="page-sub">Gross Pay and Net Pay are computed automatically.</p>

    <div class="card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="EmployeeId"></label>
                <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeId">
                    <option value="">-- Select Employee --</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="Date"></label>
                <input asp-for="Date" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="DaysWorked"></label>
                    <input asp-for="DaysWorked" type="number" placeholder="0" />
                    <span asp-validation-for="DaysWorked" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Deduction"></label>
                    <input asp-for="Deduction" type="number" placeholder="0.00" />
                    <span asp-validation-for="Deduction" class="text-danger"></span>
                </div>
            </div>
            <p class="hint">💡 Gross Pay = Days Worked × Daily Rate &nbsp;|&nbsp; Net Pay = Gross Pay − Deduction</p>
            <button type="submit" class="btn-submit">Generate Payroll</button>
        </form>
    </div>
    <a href="/Payroll" class="back-link">← Back to Payroll</a>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }