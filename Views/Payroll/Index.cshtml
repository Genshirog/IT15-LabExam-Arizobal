@model IEnumerable<LabExam1.Models.Payroll>
@{ ViewData["Title"] = "Payroll"; }

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg: #0f1117; --surface: #1a1d27; --surface2: #22263a;
        --accent: #6c63ff; --accent3: #43e97b; --accent2: #ff6584;
        --text: #e8eaf6; --muted: #7b7f9e; --border: rgba(255,255,255,0.07);
    }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; }
    .page { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .page-title { font-family: 'Syne', sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0;
        background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .btn { padding: 0.6rem 1.2rem; border-radius: 8px; font-size: 0.85rem; font-weight: 500;
        text-decoration: none; border: none; cursor: pointer; transition: all 0.2s; display: inline-block; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: #5a52e0; color: #fff; transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--muted); font-size: 0.8rem; padding: 0.3rem 0.6rem; }
    .btn-ghost:hover { color: var(--text); }
    .btn-danger-ghost { background: transparent; color: var(--accent2); font-size: 0.8rem; padding: 0.3rem 0.6rem; }
    .btn-danger-ghost:hover { color: #ff4a6e; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 0.75rem 1.5rem; font-size: 0.7rem; text-transform: uppercase;
        letter-spacing: 0.08em; color: var(--muted); text-align: left; background: var(--surface2); }
    tbody tr { border-top: 1px solid var(--border); transition: background 0.15s; }
    tbody tr:hover { background: var(--surface2); }
    tbody td { padding: 0.9rem 1.5rem; font-size: 0.875rem; }
    .pill { display: inline-block; padding: 0.2rem 0.65rem; border-radius: 20px; font-size: 0.75rem; font-weight: 500; }
    .pill-green { background: rgba(67,233,123,0.12); color: var(--accent3); }
    .pill-purple { background: rgba(108,99,255,0.12); color: var(--accent); }
    .pill-red { background: rgba(255,101,132,0.12); color: var(--accent2); }
    .back-link { display: inline-block; margin-top: 1.5rem; color: var(--muted); font-size: 0.85rem; text-decoration: none; }
    .back-link:hover { color: var(--text); }
</style>

<div class="page">
    <div class="page-header">
        <h1 class="page-title">Payroll Records</h1>
        <a href="/Payroll/Create" class="btn btn-primary">+ New Payroll</a>
    </div>
    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Date</th>
                    <th>Days Worked</th>
                    <th>Gross Pay</th>
                    <th>Deduction</th>
                    <th>Net Pay</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Employee?.FirstName @item.Employee?.LastName</strong></td>
                        <td style="color:var(--muted);font-size:0.8rem;">@item.Date.ToString("MMM dd, yyyy")</td>
                        <td>@item.DaysWorked days</td>
                        <td><span class="pill pill-purple">₱@item.GrossPay.ToString("N2")</span></td>
                        <td><span class="pill pill-red">₱@item.Deduction.ToString("N2")</span></td>
                        <td><span class="pill pill-green">₱@item.NetPay.ToString("N2")</span></td>
                        <td style="text-align:right;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-ghost">Edit</a> |
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-ghost">Details</a> |
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger-ghost">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <a href="/" class="back-link">← Back to Dashboard</a>
</div>